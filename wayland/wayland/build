#!/bin/sh -e

export DESTDIR="$1"

#sed -i "s/expat'/expat', static: true/" meson.build
#sed -i "s/ffi'/ffi', static: true, /"   meson.build
#sed -i "s/subdir('tests')//"            meson.build


#    -Ddefault_library=static \
meson \
    --prefix=/usr \
    -Dbuildtype=release \
    -Ddocumentation=false \
    -Ddtd_validation=false \
    . build

ninja -C build
ninja -C build install
